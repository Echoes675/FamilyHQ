# Copy to scripts/DevStack/.env to override the local Postgres container credentials.
# These are throwaway creds for a purely-local, ephemeral container. .env is git-ignored.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Host port to publish the dev Postgres container on. Default 5433 to avoid clashing with
# a local Postgres already running on 5432.
POSTGRES_HOST_PORT=5433
