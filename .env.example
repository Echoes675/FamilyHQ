# Docker image tag
IMAGE_TAG=latest

# WebUi — BackendUrl injected at container startup
BACKEND_URL=https://familyhq.api.alphaepsilon.co.uk

# WebApi — Database
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=FamilyHQ;Username=postgres;Password=changeme

# WebApi — JWT
Jwt__SigningKey=changeme

# WebApi — Google Calendar (use Simulator URLs for dev/staging)
GoogleCalendar__ClientId=changeme
GoogleCalendar__ClientSecret=changeme
GoogleCalendar__AuthBaseUrl=https://accounts.google.com
GoogleCalendar__CalendarApiBaseUrl=https://www.googleapis.com/calendar/v3

# WebApi — CORS origin (must match the URL users access the UI on)
FrontendBaseUrl=https://familyhq.alphaepsilon.co.uk

# WebApi — Data Protection certificate
DataProtection__CertificatePassword=changeme

# Simulator — Database (dev/staging only)
Simulator__ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=FamilyHQ-Simulator;Username=postgres;Password=changeme

# PostgreSQL external network name
POSTGRES_NETWORK_NAME=postgres_default

# Production only — nginx-proxy-ssl routing
VIRTUAL_HOST_UI=familyhq.alphaepsilon.co.uk
VIRTUAL_HOST_API=familyhq.api.alphaepsilon.co.uk
LETSENCRYPT_HOST_UI=familyhq.alphaepsilon.co.uk
LETSENCRYPT_HOST_API=familyhq.api.alphaepsilon.co.uk
LETSENCRYPT_EMAIL=admin@alphaepsilon.co.uk
APP_NETWORK_NAME=nginx-proxy-ssl_default
