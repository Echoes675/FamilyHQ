@page "/"
@using FamilyHQ.WebUi.Components
@using FamilyHQ.WebUi.Services
@using FamilyHQ.WebUi.Services.Auth
@using FamilyHQ.WebUi.Models
@inject IAuthenticationService AuthService
@inject ICalendarApiService CalendarApiService
@inject IUserPreferencesService PreferencesService
@inject IWeatherService WeatherService
@inject NavigationManager NavigationManager

@if (!IsAuthenticated)
{
    <!-- Not Authenticated - Show centered login button -->
    <div class="kiosk-loading">
        <p>Loading...</p>
    </div>
}
else
{
    <!-- DashboardHeader controls the active view and selected date -->
    <DashboardHeader 
        ActiveView="@ActiveView"
        SelectedDate="@SelectedDate"
        Calendars="@Calendars"
        OnViewChanged="HandleViewChanged"
        OnDateChanged="HandleDateChanged"
        OnDaySelected="HandleDaySelected" />
    
    <!-- View area -->
    <div class="kiosk-view-area">
        @if (ActiveView == ActiveViewType.Today)
        {
            <TodayView SelectedDate="@SelectedDate"
                       OnEventSelected="HandleEventSelected"
                       OnDaySelected="HandleDaySelected" />
        }
        else if (ActiveView == ActiveViewType.Week)
        {
            <WeekView SelectedDate="@SelectedDate"
                      OnEventSelected="HandleEventSelected"
                      OnDaySelected="HandleDaySelected" />
        }
        else if (ActiveView == ActiveViewType.Month)
        {
            <CalendarGrid Year="@SelectedDate.Year"
                          Month="@SelectedDate.Month"
                          EventDensity="@PreferencesService.Current.EventDensity"
                          OnEventSelected="HandleEventSelected"
                          OnDaySelected="HandleDaySelected" />
        }
    </div>
    
    <!-- Event Modal (shown when an event is clicked or new event is created) -->
    <EventModal IsVisible="@ShowEventModal"
                EditingEvent="@SelectedEvent"
                DefaultDate="@SelectedDate"
                Calendars="@Calendars"
                OnClose="CloseEventModal"
                OnSaved="HandleEventSaved" />
    
    <!-- Floating Action Button for new event -->
    <button class="fab-new-event" @onclick="OpenNewEventModal" title="New Event">
        +
    </button>
}

@code {
    private bool IsAuthenticated = false;
    private ActiveViewType ActiveView = ActiveViewType.Today; // Default: Today View
    private DateOnly SelectedDate = DateOnly.FromDateTime(DateTime.Today);
    private List<CalendarSummaryViewModel> Calendars = new();
    private bool ShowEventModal = false;
    private CalendarEventViewModel? SelectedEvent = null;

    protected override async Task OnInitializedAsync()
    {
        // Check authentication
        IsAuthenticated = await AuthService.IsAuthenticatedAsync();
        if (!IsAuthenticated)
        {
            // Not authenticated - redirect to login
            NavigationManager.NavigateTo("/login");
            return;
        }
        
        // Load calendars
        try
        {
            Calendars = (await CalendarApiService.GetCalendarsAsync()).ToList();
        }
        catch { /* Handle gracefully */ }
        
        // Load user preferences
        await PreferencesService.LoadAsync();
        
        // Start weather service
        await WeatherService.StartAsync();
    }

    private void HandleViewChanged(ActiveViewType view)
    {
        ActiveView = view;
        StateHasChanged();
    }

    private void HandleDateChanged(DateOnly date)
    {
        SelectedDate = date;
        StateHasChanged();
    }

    private void HandleDaySelected(DateOnly day)
    {
        SelectedDate = day;
        // Switch to Today view when a day is tapped in month view
        ActiveView = ActiveViewType.Today;
        StateHasChanged();
    }

    private void HandleEventSelected(CalendarEventViewModel evt)
    {
        SelectedEvent = evt;
        ShowEventModal = true;
        StateHasChanged();
    }

    private void OpenNewEventModal()
    {
        SelectedEvent = null; // null = create mode
        ShowEventModal = true;
        StateHasChanged();
    }

    private void CloseEventModal()
    {
        ShowEventModal = false;
        SelectedEvent = null;
        StateHasChanged();
    }

    private async Task HandleEventSaved(CalendarEventViewModel evt)
    {
        CloseEventModal();
        // Refresh the current view
        StateHasChanged();
    }
}
