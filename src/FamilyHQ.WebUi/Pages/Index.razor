@page "/"
@using FamilyHQ.WebUi.Services
@using FamilyHQ.WebUi.Services.Auth
@using FamilyHQ.Core.DTOs
@using FamilyHQ.WebUi.ViewModels
@implements IAsyncDisposable
@inject ICalendarApiService CalendarApi
@inject SignalRService SignalR
@inject NavigationManager NavigationManager
@inject IConfiguration Configuration
@inject IAuthenticationService AuthService
@inject IJSRuntime JSRuntime

<PageTitle>FamilyHQ Dashboard</PageTitle>

<div class="dashboard-container">
    @if (!_isAuthenticated)
    {
        <!-- Not Authenticated - Show centered login button -->
        <div class="d-flex flex-column align-items-center justify-content-center" style="min-height: 60vh;">
            <h1 class="mb-4">Family HQ Dashboard</h1>
            <p class="text-muted mb-4">Please sign in to view your calendar</p>
            <button class="btn btn-success btn-lg" @onclick="OnLoginClicked">Login to Google</button>
        </div>
    }
    else
    {
        <!-- Authenticated - Show full dashboard with header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="d-flex align-items-center gap-3">
                <h1>Family HQ Dashboard</h1>
            </div>
            
            <!-- User Info and Sign Out (Top Right) -->
            <div class="d-flex align-items-center gap-3">
                <span class="text-muted">Signed in as: <strong>@(_username ?? _userId ?? "Unknown")</strong></span>
                <button class="btn btn-outline-danger btn-sm" @onclick="OnSignOutClicked">Sign Out</button>
            </div>
        </div>

        <ul class="nav nav-tabs mb-4">
            <li class="nav-item">
                <button data-testid="month-tab" class="nav-link @(_currentView == DashboardView.Month ? "active" : "")" @onclick="() => SwitchToView(DashboardView.Month)">Month View</button>
            </li>
            <li class="nav-item">
                <button data-testid="agenda-tab" class="nav-link @(_currentView == DashboardView.MonthAgenda ? "active" : "")" @onclick="() => SwitchToView(DashboardView.MonthAgenda)">Agenda</button>
            </li>
            <li class="nav-item">
                <button data-testid="day-tab" class="nav-link @(_currentView == DashboardView.Day ? "active" : "")" @onclick="() => SwitchToView(DashboardView.Day)">Day View</button>
            </li>
        </ul>

        @if (_currentView == DashboardView.Month)
        {
            <div class="d-flex justify-content-between align-items-center mb-4">
                <!-- Navigation Controls -->
                <div class="btn-group">
                    <button class="btn btn-outline-primary" @onclick="GoToPreviousMonth">&lt; Prev</button>
                    <button class="btn btn-light" style="min-width: 150px; font-weight: 600;" @onclick="OpenQuickJumpModal">
                        @CurrentMonth.ToString("MMMM yyyy")
                    </button>
                    <button class="btn btn-outline-primary" @onclick="GoToNextMonth">Next &gt;</button>
                </div>
                
                <button class="btn btn-primary ms-3" @onclick="() => OpenAddEventModal(DateTime.Today)" data-testid="add-event-btn">
                    <i class="bi bi-plus-circle"></i> Add Event
                </button>
            </div>
        }
        else if (_currentView == DashboardView.MonthAgenda)
        {
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="btn-group">
                    <button class="btn btn-outline-primary" data-testid="agenda-prev-month" @onclick="GoToPreviousMonth">&lt; Prev</button>
                    <button class="btn btn-light" style="min-width: 150px; font-weight: 600;" data-testid="agenda-month-year-label" @onclick="OpenQuickJumpModal">
                        @CurrentMonth.ToString("MMMM yyyy")
                    </button>
                    <button class="btn btn-outline-primary" data-testid="agenda-next-month" @onclick="GoToNextMonth">Next &gt;</button>
                </div>
                <button class="btn btn-primary ms-3" data-testid="agenda-create-button" @onclick="() => OpenAddEventModal(DateTime.Today)">
                    <i class="bi bi-plus-circle"></i> Add Event
                </button>
            </div>
        }
        else if (_currentView == DashboardView.Day)
        {
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="btn-group">
                    <button class="btn btn-outline-primary" @onclick="() => SwitchToView(DashboardView.Day, _selectedDate.AddDays(-1))">&lt; Prev</button>
                    <button class="btn btn-light" style="min-width: 150px; font-weight: 600;" @onclick="OpenDayPickerModal" data-testid="day-picker-btn">
                        @_selectedDate.ToString("D")
                    </button>
                    <button class="btn btn-outline-primary" @onclick="() => SwitchToView(DashboardView.Day, _selectedDate.AddDays(1))">Next &gt;</button>
                </div>
                
                <button class="btn btn-primary ms-3" @onclick="() => OpenAddEventModal(_selectedDate)" data-testid="add-event-btn">
                    <i class="bi bi-plus-circle"></i> Add Event
                </button>
            </div>
        }
    }

    @if (_isAuthenticated)
    {
    @if (IsLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2 text-muted">Synchronizing Calendar...</p>
        </div>
    }
    else if (_monthView == null)
    {
        <div class="alert alert-warning">
            Failed to load calendar data. Please ensure the backend is running and authenticated.
        </div>
    }
    else
    {
    @if (_currentView == DashboardView.Month)
    {
        <table class="month-table">
            <thead>
                <tr>
                    <th style="width: 14.28%">Sun</th>
                    <th style="width: 14.28%">Mon</th>
                    <th style="width: 14.28%">Tue</th>
                    <th style="width: 14.28%">Wed</th>
                    <th style="width: 14.28%">Thu</th>
                    <th style="width: 14.28%">Fri</th>
                    <th style="width: 14.28%">Sat</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var week in _weeks)
                {
                    <tr>
                        @foreach (var day in week)
                        {
                            var isCurrentMonth = day.Date.Month == CurrentMonth.Month;
                            var isToday = day.Date.Date == DateTime.Today;
                            var isWeekend = day.Date.DayOfWeek == DayOfWeek.Saturday || day.Date.DayOfWeek == DayOfWeek.Sunday;
                            
                            var cssClass = "calendar-cell";
                            if (!isCurrentMonth) cssClass += " text-muted bg-light";
                            if (isToday) cssClass += " today-cell";
                            else if (isWeekend && isCurrentMonth) cssClass += " weekend-cell";

                            <td class="@cssClass" id="day-cell-@day.Date.ToString("yyyy-MM-dd")">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span style="font-weight: @(isToday ? "700" : "400")">
                                        @day.Date.Day
                                    </span>
                                    <button class="btn btn-sm btn-link p-0 text-muted shadow-none" title="Add event on this day" @onclick="() => OpenAddEventModal(day.Date)">
                                        <span style="font-size: 1.2rem; line-height: 1;">+</span>
                                    </button>
                                </div>
                                
                                <div class="mt-2">
                                    @* Display up to 3 events *@
                                    @foreach (var evt in day.Events.Take(3))
                                    {
                                        <div class="event-capsule" 
                                             style="background-color: @(evt.CalendarColor ?? "var(--primary)"); cursor: pointer;"
                                             title="@evt.Title (@evt.Start.ToString("t")) - @evt.Location"
                                             @onclick="() => OpenEditEventModal(evt)">
                                            @if (evt.IsAllDay)
                                            {
                                                <span>@evt.Title</span>
                                            }
                                            else
                                            {
                                                <span><b>@evt.Start.ToString("h:mm tt")</b> @evt.Title</span>
                                            }
                                        </div>
                                    }
                                    
                                    @if(day.Events.Count() > 3)
                                    {
                                        <div class="overflow-indicator mt-1 text-center" @onclick="() => SwitchToView(DashboardView.Day, day.Date)" data-testid="overflow-indicator">
                                            +@(day.Events.Count() - 3) more
                                        </div>
                                    }
                                </div>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    }
    else if (_currentView == DashboardView.Day)
    {
        var key = _selectedDate.ToString("yyyy-MM-dd");
        var dayEvents = _monthView.Days.TryGetValue(key, out var evts) ? evts : new List<CalendarEventViewModel>();
        
        <div class="day-view-container" id="day-view-container">
            <div class="day-view-sticky-header">
                <!-- Headers -->
                <div class="day-header">
                <div class="time-axis-header"></div>
                @foreach (var cal in _calendars)
                {
                    <div class="calendar-header-col" title="@cal.DisplayName">@cal.DisplayName</div>
                }
            </div>
            
            <!-- All Day Row -->
            <div class="all-day-container">
                <div class="all-day-label">All Day</div>
                @foreach (var cal in _calendars)
                {
                    var calAllDayEvents = dayEvents.Where(e => e.CalendarInfoId == cal.Id && e.IsAllDay).ToList();
                    <div class="all-day-col">
                        @foreach (var evt in calAllDayEvents)
                        {
                            <div class="event-capsule" style="background-color: @(evt.CalendarColor ?? "var(--primary)");"
                                 title="@evt.Title"
                                 @onclick="() => OpenEditEventModal(evt)">
                                @evt.Title
                            </div>
                        }
                    </div>
                }
            </div>
            </div> <!-- .day-view-sticky-header -->
            
            <!-- Scrollable Body -->
            <div class="day-body-scrollable" id="day-body-scrollable">
                <div class="day-body-flex">
                    <!-- Current Time Line -->
                    @if (_selectedDate == DateTime.Today)
                    {
                        <div class="current-time-line" style="top: @GetCurrentTimeTopPosition()%" id="current-time-line"></div>
                    }

                    <!-- Time Axis -->
                    <div class="time-axis">
                        @for (int i = 0; i < 24; i++)
                        {
                            var topPos = (i / 24.0) * 100;
                            var label = i == 0 ? "12 AM" : i < 12 ? $"{i} AM" : i == 12 ? "12 PM" : $"{i - 12} PM";
                            if (i > 0)
                            {
                                <div class="time-slot-label" style="top: @topPos%">@label</div>
                            }
                        }
                    </div>
                    
                    <!-- Grid Lines -->
                    <div class="hour-lines-container">
                        @for (int i = 1; i < 24; i++)
                        {
                            <div class="hour-line" style="top: @((i / 24.0) * 100)%"></div>
                        }
                    </div>
                    
                    <!-- Columns -->
                    <div class="calendar-cols-container">
                        @foreach (var cal in _calendars)
                        {
                            var calEvents = dayEvents.Where(e => e.CalendarInfoId == cal.Id).ToList();
                            var placedEvents = GetPlacedEvents(calEvents);
                            
                            <div class="calendar-col" @onclick="(e) => OnDayGridClick(e, _selectedDate, cal.Id)">
                                @foreach (var p in placedEvents)
                                {
                                    <div class="day-event-block" 
                                         style="@GetEventStyle(p, _selectedDate)" 
                                         title="@($"{p.Event.Title}\n{p.Event.Start.LocalDateTime:t} - {p.Event.End.LocalDateTime:t}\n{p.Event.Location}")"
                                         @onclick:stopPropagation="true"
                                         @onclick="() => OpenEditEventModal(p.Event)">
                                        <div class="fw-bold">@p.Event.Title</div>
                                        <div>@p.Event.Start.LocalDateTime.ToString("h:mm tt")</div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else if (_currentView == DashboardView.MonthAgenda)
    {
        <div class="agenda-view-container">
            <table class="agenda-table">
                <thead>
                    <tr class="agenda-header-row">
                        <th class="agenda-day-col">Day</th>
                        @foreach (var cal in _calendars)
                        {
                            <th data-testid="@($"agenda-calendar-header-{cal.Id}")" class="agenda-cal-col">
                                <span class="cal-color-dot" style="background-color: @(cal.Color ?? "#9e9e9e");"></span>
                                @cal.DisplayName
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @{
                        var daysInMonth = DateTime.DaysInMonth(CurrentMonth.Year, CurrentMonth.Month);
                    }
                    @for (int d = 1; d <= daysInMonth; d++)
                    {
                        var date = new DateTime(CurrentMonth.Year, CurrentMonth.Month, d);
                        var dateKey = date.ToString("yyyy-MM-dd");
                        var isWeekend = date.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
                        var isToday = date.Date == DateTime.Today;
                        var rowCss = "agenda-day-row"
                            + (isWeekend ? " agenda-weekend-row" : "")
                            + (isToday ? " agenda-today-row" : "");

                        <tr class="@rowCss">
                            <td data-testid="@($"agenda-day-label-{dateKey}")" class="agenda-day-col">
                                @date.ToString("ddd dd")
                            </td>
                            @foreach (var cal in _calendars)
                            {
                                var dayEvents = (_monthView.Days.TryGetValue(dateKey, out var dayList)
                                        ? dayList
                                        : new List<CalendarEventViewModel>())
                                    .Where(e => e.CalendarInfoId == cal.Id)
                                    .OrderBy(e => (e.IsAllDay || e.Start.Date < date.Date) ? 0 : 1)
                                    .ThenBy(e => e.Start)
                                    .ToList();

                                <td data-testid="@($"agenda-cell-{dateKey}-{cal.Id}")"
                                    class="agenda-cal-cell"
                                    @onclick="() => OpenAddEventModal(date, cal.Id)">
                                    @foreach (var evt in dayEvents.Take(3))
                                    {
                                        var isContinuation = !evt.IsAllDay && evt.Start.Date < date.Date;
                                        var displayText = (evt.IsAllDay || isContinuation)
                                            ? evt.Title
                                            : $"{evt.Start.LocalDateTime:HH:mm} {evt.Title}";

                                        <div data-testid="@($"agenda-event-{evt.Id}-{cal.Id}")"
                                             class="agenda-event-line"
                                             @onclick="() => OpenEditEventModal(evt)"
                                             @onclick:stopPropagation="true">
                                            @displayText
                                        </div>
                                    }
                                    @if (dayEvents.Count > 3)
                                    {
                                        <div data-testid="@($"agenda-overflow-{dateKey}-{cal.Id}")"
                                             class="agenda-overflow-btn"
                                             @onclick="() => SwitchToView(DashboardView.Day, date)"
                                             @onclick:stopPropagation="true">
                                            +@(dayEvents.Count - 3) more
                                        </div>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    }
    }
</div>

@if (_showQuickJumpModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title w-100 text-center">Jump to Date</h5>
                    <button type="button" class="btn-close" @onclick="CloseQuickJumpModal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => _jumpYear--">&lt;</button>
                        <span class="fs-5 fw-bold">@_jumpYear</span>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => _jumpYear++">&gt;</button>
                    </div>
                    
                    <div class="row g-2">
                        @for (int i = 1; i <= 12; i++)
                        {
                            var month = i; // local capture for lambda
                            <div class="col-4">
                                <button class="btn w-100 @(IsSelectedJumpMonth(month) ? "btn-primary" : "btn-outline-primary")"
                                        @onclick="() => JumpToDate(month)">
                                    @(new DateTime(2000, month, 1).ToString("MMM"))
                                </button>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0 justify-content-center">
                    <button class="btn btn-link text-decoration-none" @onclick="JumpToToday">Go to Today</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showDayPickerModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header pb-2">
                    <h5 class="modal-title">Select Date</h5>
                    <button type="button" class="btn-close" @onclick="CloseDayPickerModal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-center">
                    <input type="date" class="form-control mb-3" @bind="_pickedDate" data-testid="day-picker-input" />
                    <button class="btn btn-primary w-100 mb-2" @onclick="JumpToPickedDay" data-testid="day-picker-go-btn">Go Context</button>
                    <button class="btn btn-outline-secondary w-100" @onclick="JumpToTodayDayView" data-testid="day-picker-today-btn">Jump to Today</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showEventModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_isEditingEvent ? "Edit Event" : "Create Event")</h5>
                    <button type="button" class="btn-close" @onclick="CloseEventModal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Calendars</label>
                        <CalendarChipSelector
                            AllCalendars="_calendars"
                            SelectedCalendarIds="_selectedCalendarIds"
                            SelectedCalendarIdsChanged="ids => { _selectedCalendarIds = ids; }"
                            EventId="@(_isEditingEvent ? (Guid?)_eventModel.Id : null)"
                            CalendarApi="CalendarApi" />
                        @if (_selectedCalendarIds.Count == 0)
                        {
                            <div class="text-danger mt-1" style="font-size: 0.82rem;">Please select at least one calendar.</div>
                        }
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Event Title</label>
                        <input type="text" class="form-control" @bind="_eventModel.Title" placeholder="e.g. Doctor Appointment" />
                    </div>
                    
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="allDayCheck" @bind="_eventModel.IsAllDay">
                        <label class="form-check-label" for="allDayCheck">All Day Event</label>
                    </div>

                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label">Start</label>
                            @if (_eventModel.IsAllDay)
                            {
                                <input type="date" class="form-control" @bind="@_eventModelStartDate" />
                            }
                            else
                            {
                                <input type="datetime-local" class="form-control" @bind="_eventModel.Start" />
                            }
                        </div>
                        <div class="col-6">
                            <label class="form-label">End</label>
                            @if (_eventModel.IsAllDay)
                            {
                                <input type="date" class="form-control" @bind="@_eventModelEndDate" />
                            }
                            else
                            {
                                <input type="datetime-local" class="form-control" @bind="_eventModel.End" />
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Location (Optional)</label>
                        <input type="text" class="form-control" @bind="_eventModel.Location" placeholder="e.g. 123 Main St" />
                    </div>

                    @if (!string.IsNullOrEmpty(_modalError))
                    {
                        <div class="alert alert-danger p-2 mb-0">@_modalError</div>
                    }
                </div>
                <div class="modal-footer d-flex justify-content-between">
                    <div>
                        @if (_isEditingEvent)
                        {
                            <button type="button" class="btn btn-outline-danger" @onclick="DeleteEvent">Delete</button>
                        }
                    </div>
                    <div>
                        <button type="button" class="btn btn-secondary" @onclick="CloseEventModal">Cancel</button>
                        <button type="button" class="btn btn-primary" @onclick="SaveEvent" disabled="@_isSaving">
                            @if (_isSaving)
                            {
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                <span class="visually-hidden">Saving...</span>
                            }
                            else
                            {
                                <span>Save</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private enum DashboardView { Month, MonthAgenda, Day }
    private DashboardView _currentView = DashboardView.Month;
    private DateTime _selectedDate = DateTime.Today;

    // Authentication State
    private bool _isAuthenticated;
    private string? _username;
    private string? _userId;

    private DateTime CurrentMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private bool IsLoading = true;
    private MonthViewModel? _monthView;
    private List<List<DayItem>> _weeks = new();

    // Quick Jump Modal State
    private bool _showQuickJumpModal = false;
    private int _jumpYear;

    // Day Picker Modal State
    private bool _showDayPickerModal = false;
    private DateTime _pickedDate = DateTime.Today;

    // Event Modal State
    private bool _showEventModal = false;
    private bool _isEditingEvent = false;
    private EventFormModel _eventModel = new();
    private HashSet<Guid> _selectedCalendarIds = new();
    private IReadOnlyList<CalendarSummaryViewModel> _calendars = Array.Empty<CalendarSummaryViewModel>();
    private string? _modalError;
    private bool _isSaving = false;

    // Helper properties for All-day date binding
    private DateTime _eventModelStartDate
    {
        get => _eventModel.Start.LocalDateTime.Date;
        set => _eventModel.Start = new DateTimeOffset(value.Date, TimeSpan.Zero);
    }
    private DateTime _eventModelEndDate
    {
        get => _eventModel.End.LocalDateTime.Date;
        set => _eventModel.End = new DateTimeOffset(value.Date.AddDays(1).AddTicks(-1), TimeSpan.Zero);
    }

    protected override async Task OnInitializedAsync()
    {
        // Check authentication state
        _isAuthenticated = await AuthService.IsAuthenticatedAsync();
        _username = await AuthService.GetUsernameAsync();
        _userId = await AuthService.GetUserIdAsync();
        
        if (!_isAuthenticated)
        {
            // Not authenticated - show login prompt only
            return;
        }

        // Authenticated - load calendar data
        _calendars = await CalendarApi.GetCalendarsAsync();
        
        SignalR.OnEventsUpdated += RefreshDataFromSignalR;
        await SignalR.StartAsync();
        
        await LoadMonthDataAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_currentView == DashboardView.Day && _selectedDate.Date == DateTime.Today)
        {
            try
            {
                var currentMins = DateTime.Now.TimeOfDay.TotalMinutes;
                await JSRuntime.InvokeVoidAsync("eval", $@"
                    var c = document.getElementById('day-view-container');
                    if(c && !c.dataset.scrolled) {{
                        c.dataset.scrolled = 'true';
                        var target = ({currentMins} / 1440) * 1440;
                        c.scrollTop = target - (c.clientHeight / 4);
                    }}
                ");
            }
            catch { /* Ignored if JSInterop fails on first render */ }
        }
        else if (_currentView != DashboardView.Day)
        {
            // Reset scroll tracking
            try
            {
                await JSRuntime.InvokeVoidAsync("eval", "var c = document.getElementById('day-view-container'); if(c) c.removeAttribute('data-scrolled');");
            }
            catch { }
        }
    }

    private void RefreshDataFromSignalR()
    {
        // Must be invoked on the UI thread
        InvokeAsync(async () =>
        {
            _calendars = await CalendarApi.GetCalendarsAsync();
            await LoadMonthDataAsync();
            StateHasChanged();
        });
    }

    private async Task LoadMonthDataAsync()
    {
        IsLoading = true;
        StateHasChanged();

        _monthView = await CalendarApi.GetEventsForMonthAsync(CurrentMonth.Year, CurrentMonth.Month);
        
        BuildCalendarGrid();
        
        IsLoading = false;
        StateHasChanged();
    }

    private void BuildCalendarGrid()
    {
        _weeks.Clear();
        
        // Get start of the first week (could be late previous month)
        var firstDayOfMonth = new DateTime(CurrentMonth.Year, CurrentMonth.Month, 1);
        var startDay = firstDayOfMonth.AddDays(-(int)firstDayOfMonth.DayOfWeek);
        
        var currentDay = startDay;
        
        // Build 6 weeks to ensure we cover all days cleanly formatted
        for (int row = 0; row < 6; row++)
        {
            var week = new List<DayItem>();
            for (int col = 0; col < 7; col++)
            {
                var dateKey = currentDay.ToString("yyyy-MM-dd");
                var eventsForDay = new List<CalendarEventViewModel>();
                
                if (_monthView != null && _monthView.Days.ContainsKey(dateKey))
                {
                    eventsForDay = _monthView.Days[dateKey]
                        .OrderByDescending(e => e.IsAllDay)
                        .ThenBy(e => e.Start)
                        .ToList();
                }

                week.Add(new DayItem { Date = currentDay, Events = eventsForDay });
                currentDay = currentDay.AddDays(1);
            }
            _weeks.Add(week);
            
            // If we've passed the end of the month and completed the row, stop
            if (currentDay.Month > CurrentMonth.Month || 
               (currentDay.Year > CurrentMonth.Year && currentDay.Month == 1))
            {
                break;
            }
        }
    }

    private async Task GoToPreviousMonth()
    {
        CurrentMonth = CurrentMonth.AddMonths(-1);
        await LoadMonthDataAsync();
    }

    private async Task GoToNextMonth()
    {
        CurrentMonth = CurrentMonth.AddMonths(1);
        await LoadMonthDataAsync();
    }
    
    // View Switching Logic
    private async Task SwitchToView(DashboardView view, DateTime? date = null)
    {
        _currentView = view;
        if (date.HasValue)
        {
            _selectedDate = date.Value.Date;
            if (_selectedDate.Month != CurrentMonth.Month || _selectedDate.Year != CurrentMonth.Year)
            {
                CurrentMonth = new DateTime(_selectedDate.Year, _selectedDate.Month, 1);
                await LoadMonthDataAsync();
            }
        }
        else if (view == DashboardView.Day && _selectedDate == default)
        {
            _selectedDate = DateTime.Today;
            if (_selectedDate.Month != CurrentMonth.Month || _selectedDate.Year != CurrentMonth.Year)
            {
                CurrentMonth = new DateTime(_selectedDate.Year, _selectedDate.Month, 1);
                await LoadMonthDataAsync();
            }
        }
        StateHasChanged();
    }
    
