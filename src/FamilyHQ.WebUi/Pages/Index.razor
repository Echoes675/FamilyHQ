@page "/"
@using FamilyHQ.WebUi.Services
@using FamilyHQ.Core.DTOs
@using FamilyHQ.Core.ViewModels
@using FamilyHQ.Core.Models
@implements IAsyncDisposable
@inject ICalendarApiService CalendarApi
@inject SignalRService SignalR

<PageTitle>FamilyHQ Dashboard</PageTitle>

<div class="dashboard-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-3">
            <h1>Family HQ Dashboard</h1>
            <button class="btn btn-sm btn-success" @onclick="OpenLoginModal">Login to Google (Simulator)</button>
        </div>
        
        <!-- Navigation Controls -->
        <div class="btn-group">
            <button class="btn btn-outline-primary" @onclick="GoToPreviousMonth">&lt; Prev</button>
            <button class="btn btn-light" style="min-width: 150px; font-weight: 600;" @onclick="OpenQuickJumpModal">
                @CurrentMonth.ToString("MMMM yyyy")
            </button>
            <button class="btn btn-outline-primary" @onclick="GoToNextMonth">Next &gt;</button>
        </div>
        
        <button class="btn btn-primary ms-3" @onclick="() => OpenAddEventModal(DateTime.Today)">
            <i class="bi bi-plus-circle"></i> Add Event
        </button>
    </div>

    @if (IsLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2 text-muted">Synchronizing Calendar...</p>
        </div>
    }
    else if (_monthView == null)
    {
        <div class="alert alert-warning">
            Failed to load calendar data. Please ensure the backend is running and authenticated.
        </div>
    }
    else
    {
        <table class="month-table">
            <thead>
                <tr>
                    <th style="width: 14.28%">Sun</th>
                    <th style="width: 14.28%">Mon</th>
                    <th style="width: 14.28%">Tue</th>
                    <th style="width: 14.28%">Wed</th>
                    <th style="width: 14.28%">Thu</th>
                    <th style="width: 14.28%">Fri</th>
                    <th style="width: 14.28%">Sat</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var week in _weeks)
                {
                    <tr>
                        @foreach (var day in week)
                        {
                            var isCurrentMonth = day.Date.Month == CurrentMonth.Month;
                            var isToday = day.Date.Date == DateTime.Today;
                            var isWeekend = day.Date.DayOfWeek == DayOfWeek.Saturday || day.Date.DayOfWeek == DayOfWeek.Sunday;
                            
                            var cssClass = "calendar-cell";
                            if (!isCurrentMonth) cssClass += " text-muted bg-light";
                            if (isToday) cssClass += " today-cell";
                            else if (isWeekend && isCurrentMonth) cssClass += " weekend-cell";

                            <td class="@cssClass">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span style="font-weight: @(isToday ? "700" : "400")">
                                        @day.Date.Day
                                    </span>
                                    <button class="btn btn-sm btn-link p-0 text-muted shadow-none" title="Add event on this day" @onclick="() => OpenAddEventModal(day.Date)">
                                        <span style="font-size: 1.2rem; line-height: 1;">+</span>
                                    </button>
                                </div>
                                
                                <div class="mt-2">
                                    @* Display up to 3 events *@
                                    @foreach (var evt in day.Events.Take(3))
                                    {
                                        <div class="event-capsule" 
                                             style="background-color: @(evt.CalendarColor ?? "var(--primary)"); cursor: pointer;"
                                             title="@evt.Title (@evt.StartTime.ToString("t")) - @evt.Location"
                                             @onclick="() => OpenEditEventModal(evt)">
                                            @if (evt.IsAllDay)
                                            {
                                                <span>@evt.Title</span>
                                            }
                                            else
                                            {
                                                <span><b>@evt.StartTime.ToString("h:mm tt")</b> @evt.Title</span>
                                            }
                                        </div>
                                    }
                                    
                                    @if(day.Events.Count() > 3)
                                    {
                                        <div class="overflow-indicator mt-1 text-center">
                                            +@(day.Events.Count() - 3) more
                                        </div>
                                    }
                                </div>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@if (_showQuickJumpModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title w-100 text-center">Jump to Date</h5>
                    <button type="button" class="btn-close" @onclick="CloseQuickJumpModal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => _jumpYear--">&lt;</button>
                        <span class="fs-5 fw-bold">@_jumpYear</span>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => _jumpYear++">&gt;</button>
                    </div>
                    
                    <div class="row g-2">
                        @for (int i = 1; i <= 12; i++)
                        {
                            var month = i; // local capture for lambda
                            <div class="col-4">
                                <button class="btn w-100 @(IsSelectedJumpMonth(month) ? "btn-primary" : "btn-outline-primary")"
                                        @onclick="() => JumpToDate(month)">
                                    @(new DateTime(2000, month, 1).ToString("MMM"))
                                </button>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0 justify-content-center">
                    <button class="btn btn-link text-decoration-none" @onclick="JumpToToday">Go to Today</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showEventModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_isEditingEvent ? "Edit Event" : "Create Event")</h5>
                    <button type="button" class="btn-close" @onclick="CloseEventModal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Calendar</label>
                        <select class="form-select" @bind="_selectedCalendarId">
                            <option value="">-- Select Calendar --</option>
                            @foreach(var cal in _calendars.Where(c => c.IsVisible))
                            {
                                <option value="@cal.Id">@cal.DisplayName</option>
                            }
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Event Title</label>
                        <input type="text" class="form-control" @bind="_eventModel.Title" placeholder="e.g. Doctor Appointment" />
                    </div>
                    
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="allDayCheck" @bind="_eventModel.IsAllDay">
                        <label class="form-check-label" for="allDayCheck">All Day Event</label>
                    </div>

                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label">Start</label>
                            @if (_eventModel.IsAllDay)
                            {
                                <input type="date" class="form-control" @bind="@_eventModelStartDate" />
                            }
                            else
                            {
                                <input type="datetime-local" class="form-control" @bind="_eventModel.StartTime" />
                            }
                        </div>
                        <div class="col-6">
                            <label class="form-label">End</label>
                            @if (_eventModel.IsAllDay)
                            {
                                <input type="date" class="form-control" @bind="@_eventModelEndDate" />
                            }
                            else
                            {
                                <input type="datetime-local" class="form-control" @bind="_eventModel.EndTime" />
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Location (Optional)</label>
                        <input type="text" class="form-control" @bind="_eventModel.Location" placeholder="e.g. 123 Main St" />
                    </div>

                    @if (!string.IsNullOrEmpty(_modalError))
                    {
                        <div class="alert alert-danger p-2 mb-0">@_modalError</div>
                    }
                </div>
                <div class="modal-footer d-flex justify-content-between">
                    <div>
                        @if (_isEditingEvent)
                        {
                            <button type="button" class="btn btn-outline-danger" @onclick="DeleteEvent">Delete</button>
                        }
                    </div>
                    <div>
                        <button type="button" class="btn btn-secondary" @onclick="CloseEventModal">Cancel</button>
                        <button type="button" class="btn btn-primary" @onclick="SaveEvent" disabled="@_isSaving">
                            @if (_isSaving)
                            {
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                <span class="visually-hidden">Saving...</span>
                            }
                            else
                            {
                                <span>Save</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (_showLoginModal)
{
    <div class="modal fade show d-block login-modal-content" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Simulate OAuth Login</h5>
                    <button type="button" class="btn-close" @onclick="CloseLoginModal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-3">For End-to-End testing. Enter the name of the simulated user.</p>
                    <div class="mb-3">
                        <label class="form-label">Simulated User ID / Name</label>
                        <input type="text" class="form-control" @bind="_simulatedUserId" placeholder="e.g. Test Family Member" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseLoginModal">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="ConfirmSimulateLogin">Simulate OAuth &amp; Proceed</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private DateTime CurrentMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private bool IsLoading = true;
    private MonthViewDto? _monthView;
    private List<List<DayItem>> _weeks = new();

    // Quick Jump Modal State
    private bool _showQuickJumpModal = false;
    private int _jumpYear;

    // Simulated Login Modal State
    private bool _showLoginModal = false;
    private string _simulatedUserId = "Test Family Member";

    // Event Modal State
    private bool _showEventModal = false;
    private bool _isEditingEvent = false;
    private CalendarEventViewModel _eventModel = new();
    private Guid _selectedCalendarId;
    private IReadOnlyList<CalendarInfo> _calendars = Array.Empty<CalendarInfo>();
    private string? _modalError;
    private bool _isSaving = false;

    // Helper properties for All-day date binding
    private DateTime _eventModelStartDate
    {
        get => _eventModel.StartTime.Date;
        set => _eventModel.StartTime = value.Date;
    }
    private DateTime _eventModelEndDate
    {
        get => _eventModel.EndTime.Date;
        set => _eventModel.EndTime = value.Date.AddDays(1).AddTicks(-1); 
    }

    protected override async Task OnInitializedAsync()
    {
        _calendars = await CalendarApi.GetCalendarsAsync();
        
        SignalR.OnEventsUpdated += RefreshDataFromSignalR;
        await SignalR.StartAsync();
        
        await LoadMonthDataAsync();
    }

    private void RefreshDataFromSignalR()
    {
        // Must be invoked on the UI thread
        InvokeAsync(async () =>
        {
            await LoadMonthDataAsync();
            StateHasChanged();
        });
    }

    private async Task LoadMonthDataAsync()
    {
        IsLoading = true;
        StateHasChanged();

        _monthView = await CalendarApi.GetEventsForMonthAsync(CurrentMonth.Year, CurrentMonth.Month);
        
        BuildCalendarGrid();
        
        IsLoading = false;
        StateHasChanged();
    }

    private void BuildCalendarGrid()
    {
        _weeks.Clear();
        
        // Get start of the first week (could be late previous month)
        var firstDayOfMonth = new DateTime(CurrentMonth.Year, CurrentMonth.Month, 1);
        var startDay = firstDayOfMonth.AddDays(-(int)firstDayOfMonth.DayOfWeek);
        
        var currentDay = startDay;
        
        // Build 6 weeks to ensure we cover all days cleanly formatted
        for (int row = 0; row < 6; row++)
        {
            var week = new List<DayItem>();
            for (int col = 0; col < 7; col++)
            {
                var dateKey = currentDay.ToString("yyyy-MM-dd");
                var eventsForDay = new List<CalendarEventViewModel>();
                
                if (_monthView != null && _monthView.Days != null && _monthView.Days.ContainsKey(dateKey))
                {
                    eventsForDay = _monthView.Days[dateKey]
                        .OrderByDescending(e => e.IsAllDay)
                        .ThenBy(e => e.StartTime)
                        .ToList();
                }

                week.Add(new DayItem { Date = currentDay, Events = eventsForDay });
                currentDay = currentDay.AddDays(1);
            }
            _weeks.Add(week);
            
            // If we've passed the end of the month and completed the row, stop
            if (currentDay.Month > CurrentMonth.Month || 
               (currentDay.Year > CurrentMonth.Year && currentDay.Month == 1))
            {
                break;
            }
        }
    }

    private async Task GoToPreviousMonth()
    {
        CurrentMonth = CurrentMonth.AddMonths(-1);
        await LoadMonthDataAsync();
    }

    private async Task GoToNextMonth()
    {
        CurrentMonth = CurrentMonth.AddMonths(1);
        await LoadMonthDataAsync();
    }
    
    // Quick Jump Modal Logic
    private void OpenQuickJumpModal()
    {
        _jumpYear = CurrentMonth.Year;
        _showQuickJumpModal = true;
    }

    private void CloseQuickJumpModal()
    {
        _showQuickJumpModal = false;
    }

    private bool IsSelectedJumpMonth(int month) => 
        month == CurrentMonth.Month && _jumpYear == CurrentMonth.Year;

    private async Task JumpToDate(int month)
    {
        CurrentMonth = new DateTime(_jumpYear, month, 1);
        CloseQuickJumpModal();
        await LoadMonthDataAsync();
    }

    private async Task JumpToToday()
    {
        CurrentMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        CloseQuickJumpModal();
        await LoadMonthDataAsync();
    }

    private void OpenLoginModal()
    {
        _showLoginModal = true;
    }

    private void CloseLoginModal()
    {
        _showLoginModal = false;
    }

    private async Task ConfirmSimulateLogin()
    {
        _showLoginModal = false;
        IsLoading = true;
        StateHasChanged();
        
        await CalendarApi.SimulateLoginAsync(_simulatedUserId);
        
        _calendars = await CalendarApi.GetCalendarsAsync();
    }

    // Event Modal Logic
    private void OpenAddEventModal(DateTime date)
    {
        _isEditingEvent = false;
        _eventModel = new CalendarEventViewModel
        {
            Title = "",
            StartTime = date.AddHours(9), // Default to 9 AM
            EndTime = date.AddHours(10),  // Default to 10 AM
            IsAllDay = false
        };
        _selectedCalendarId = _calendars.FirstOrDefault()?.Id ?? Guid.Empty;
        _modalError = null;
        _showEventModal = true;
    }

    private void OpenEditEventModal(CalendarEventViewModel evt)
    {
        _isEditingEvent = true;
        
        // Clone to avoid mutating grid before save
        _eventModel = new CalendarEventViewModel
        {
            Id = evt.Id,
            Title = evt.Title,
            StartTime = evt.StartTime,
            EndTime = evt.EndTime,
            IsAllDay = evt.IsAllDay,
            Location = evt.Location,
            CalendarId = evt.CalendarId
        };
        
        _selectedCalendarId = evt.CalendarId;
        
        _modalError = null;
        _showEventModal = true;
    }

    private void CloseEventModal()
    {
        _showEventModal = false;
    }

    private async Task SaveEvent()
    {
        _modalError = null;
        
        if (string.IsNullOrWhiteSpace(_eventModel.Title))
        {
            _modalError = "Title is required.";
            return;
        }

        if (_selectedCalendarId == Guid.Empty)
        {
            _modalError = "Please select a calendar.";
            return;
        }

        if (_eventModel.EndTime < _eventModel.StartTime)
        {
            _modalError = "End time must be after start time.";
            return;
        }

        _isSaving = true;

        try
        {
            if (_isEditingEvent)
            {
                if (!Guid.TryParse(_eventModel.Id, out var eventId))
                {
                    _modalError = "Invalid Event ID format.";
                    return;
                }
                
                var updateReq = new UpdateEventRequest(
                    _selectedCalendarId,
                    _eventModel.Title,
                    _eventModel.StartTime,
                    _eventModel.EndTime,
                    _eventModel.IsAllDay,
                    _eventModel.Location,
                    null
                );
                await CalendarApi.UpdateEventAsync(_selectedCalendarId, eventId, updateReq);
            }
            else
            {
                var createReq = new CreateEventRequest(
                    _selectedCalendarId,
                    _eventModel.Title,
                    _eventModel.StartTime,
                    _eventModel.EndTime,
                    _eventModel.IsAllDay,
                    _eventModel.Location,
                    null
                );
                await CalendarApi.CreateEventAsync(_selectedCalendarId, createReq);
            }
            
            CloseEventModal();
            await LoadMonthDataAsync();
        }
        catch (Exception ex)
        {
            _modalError = "An error occurred while saving.";
            Console.WriteLine(ex.ToString());
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteEvent()
    {
        if (!Guid.TryParse(_eventModel.Id, out var eventId)) return;
        
        _isSaving = true;
        try
        {
            await CalendarApi.DeleteEventAsync(_selectedCalendarId, eventId);
            CloseEventModal();
            await LoadMonthDataAsync();
        }
        catch (Exception ex)
        {
            _modalError = "An error occurred while deleting.";
            Console.WriteLine(ex.ToString());
        }
        finally
        {
            _isSaving = false;
        }
    }

    public ValueTask DisposeAsync()
    {
        SignalR.OnEventsUpdated -= RefreshDataFromSignalR;
        return ValueTask.CompletedTask;
    }

    private class DayItem
    {
        public DateTime Date { get; set; }
        public List<CalendarEventViewModel> Events { get; set; } = new();
    }
}
