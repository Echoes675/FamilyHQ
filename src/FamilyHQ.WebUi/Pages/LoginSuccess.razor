@page "/login-success"
@inject FamilyHQ.WebUi.Services.Auth.IAuthTokenStore TokenStore
@inject FamilyHQ.WebUi.Services.Correlation.ICorrelationIdTokenStore CorrelationStore
@inject NavigationManager NavigationManager
@inject IHttpClientFactory HttpClientFactory
@inject ILogger<LoginSuccess> Logger
@using System.Text
@using System.Text.Json

@code {
    private record ExchangeResponse(string Token);

    protected override async Task OnInitializedAsync()
    {
        var code = ParseCodeFromQuery(NavigationManager.Uri);

        if (string.IsNullOrEmpty(code))
        {
            NavigationManager.NavigateTo("/", forceLoad: true);
            return;
        }
        var jwt = await RedeemCodeAsync(code);

        if (string.IsNullOrEmpty(jwt))
        {
            Logger.LogWarning("Exchange returned empty token for code; navigating unauthenticated");
        }

        if (!string.IsNullOrEmpty(jwt))
        {
            await TokenStore.SetTokenAsync(jwt);

            var existingSessionCorrelationId = await CorrelationStore.GetSessionCorrelationIdAsync();
            if (string.IsNullOrEmpty(existingSessionCorrelationId))
            {
                await CorrelationStore.SetSessionCorrelationIdAsync(Guid.NewGuid().ToString());
            }

        }

        NavigationManager.NavigateTo("/", forceLoad: true);
    }

    private static string? ParseCodeFromQuery(string absoluteUri)
    {
        var query = new Uri(absoluteUri).Query.TrimStart('?');
        foreach (var pair in query.Split('&'))
        {
            var parts = pair.Split('=', 2);
            if (parts.Length == 2 && parts[0] == "code")
                return Uri.UnescapeDataString(parts[1]);
        }
        return null;
    }

    private async Task<string?> RedeemCodeAsync(string code)
    {
        try
        {
            var client = HttpClientFactory.CreateClient("Auth");
            var payload = JsonSerializer.Serialize(new { code });
            using var content = new StringContent(payload, Encoding.UTF8, "application/json");
            using var response = await client.PostAsync("api/auth/exchange", content);

            if (!response.IsSuccessStatusCode)
            {
                Logger.LogWarning("Exchange code redemption failed: {StatusCode}", (int)response.StatusCode);
                return null;
            }

            var json = await response.Content.ReadAsStringAsync();
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var result = JsonSerializer.Deserialize<ExchangeResponse>(json, options);
            return result?.Token;
        }
        catch (HttpRequestException ex)
        {
            Logger.LogWarning("Exchange code redemption failed: {Error}", ex.Message);
            return null;
        }
        catch (JsonException ex)
        {
            Logger.LogWarning("Exchange code redemption failed: {Error}", ex.Message);
            return null;
        }
    }
}
