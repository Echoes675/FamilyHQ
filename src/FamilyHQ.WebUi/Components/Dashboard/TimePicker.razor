@namespace FamilyHQ.WebUi.Components.Dashboard

<div class="time-picker" role="group" aria-label="@(AriaLabel ?? "Time picker")">
    <div class="time-picker-spinners">
        <div class="time-picker-column">
            <button type="button" class="time-picker-step" aria-label="Increase hour"
                    @onclick="IncrementHour">+</button>
            <div class="time-picker-display" aria-live="polite">@Value.Hour.ToString("00")</div>
            <button type="button" class="time-picker-step" aria-label="Decrease hour"
                    @onclick="DecrementHour">−</button>
        </div>
        <div class="time-picker-separator" aria-hidden="true">:</div>
        <div class="time-picker-column">
            <button type="button" class="time-picker-step" aria-label="Increase minute"
                    @onclick="IncrementMinute">+</button>
            <div class="time-picker-display" aria-live="polite">@Value.Minute.ToString("00")</div>
            <button type="button" class="time-picker-step" aria-label="Decrease minute"
                    @onclick="DecrementMinute">−</button>
        </div>
    </div>
    <input type="text"
           class="@TextInputClass"
           inputmode="numeric"
           pattern="[0-9:]*"
           maxlength="5"
           placeholder="HH:mm"
           aria-label="@(AriaLabel ?? "Time") (type as HH:mm)"
           value="@_textValue"
           @onchange="OnTextChanged" />
</div>

<style>
    .time-picker {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .time-picker-spinners {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .time-picker-column {
        display: flex;
        flex-direction: column;
        align-items: stretch;
        gap: 6px;
        flex: 1;
        max-width: 96px;
    }

    .time-picker-step {
        min-height: 48px;
        min-width: 48px;
        border-radius: 6px;
        border: 1px solid var(--theme-glass-border);
        background: transparent;
        color: var(--theme-accent);
        font-size: 22px;
        font-weight: 600;
        line-height: 1;
        cursor: pointer;
        font-family: inherit;
        transition:
            background-color var(--theme-transition-duration, 15s) ease-in-out,
            color var(--theme-transition-duration, 15s) ease-in-out,
            border-color var(--theme-transition-duration, 15s) ease-in-out,
            transform 80ms ease-out;
        will-change: transform;
    }

    .time-picker-step:active {
        transform: scale(0.96);
        background: color-mix(in srgb, var(--theme-accent) 12%, transparent);
    }

    .time-picker-display {
        text-align: center;
        font-size: 28px;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
        color: var(--theme-text);
        padding: 8px 4px;
        border-radius: 6px;
        border: 1px solid var(--theme-glass-border);
        background: color-mix(in srgb, var(--theme-accent) 6%, transparent);
        min-height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .time-picker-separator {
        font-size: 28px;
        font-weight: 600;
        color: var(--theme-text-muted);
        padding-bottom: 2px;
    }

    .time-picker .form-input.is-invalid {
        border-color: #ef4444;
    }

    .time-picker .form-input {
        text-align: center;
        font-variant-numeric: tabular-nums;
    }
</style>

@code {
    [Parameter] public TimeOnly Value { get; set; }
    [Parameter] public EventCallback<TimeOnly> ValueChanged { get; set; }
    [Parameter] public string? AriaLabel { get; set; }

    private string _textValue = "";
    private bool _isInvalid;
    private TimeOnly _lastSyncedValue;

    private string TextInputClass => _isInvalid ? "form-input is-invalid" : "form-input";

    protected override void OnParametersSet()
    {
        if (Value != _lastSyncedValue || string.IsNullOrEmpty(_textValue))
        {
            _textValue = Value.ToString("HH:mm");
            _lastSyncedValue = Value;
            _isInvalid = false;
        }
    }

    private Task IncrementHour() => UpdateValue(TimePickerLogic.IncrementHour(Value));
    private Task DecrementHour() => UpdateValue(TimePickerLogic.DecrementHour(Value));
    private Task IncrementMinute() => UpdateValue(TimePickerLogic.IncrementMinute(Value));
    private Task DecrementMinute() => UpdateValue(TimePickerLogic.DecrementMinute(Value));

    private async Task UpdateValue(TimeOnly newValue)
    {
        Value = newValue;
        _lastSyncedValue = newValue;
        _textValue = newValue.ToString("HH:mm");
        _isInvalid = false;
        await ValueChanged.InvokeAsync(newValue);
    }

    private async Task OnTextChanged(ChangeEventArgs e)
    {
        var text = e.Value?.ToString() ?? "";
        if (TimePickerLogic.TryParse(text, out var parsed))
        {
            await UpdateValue(parsed);
        }
        else
        {
            // Keep the user's input visible so they can correct their typo; flag visually with .is-invalid.
            _isInvalid = true;
        }
    }
}
