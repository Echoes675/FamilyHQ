@using System.Text.RegularExpressions
@using FamilyHQ.Core.DTOs
@using FamilyHQ.WebUi.Services
@inject ICalendarApiService CalendarApi

@if (_showEventModal)
{
    <div class="modal-backdrop" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_isEditingEvent ? "Edit Event" : "Create Event")</h5>
                    <button type="button" class="btn-close" @onclick="Close" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Calendars</label>
                        <CalendarChipSelector
                            AllCalendars="SelectableCalendars"
                            SelectedCalendarIds="_selectedCalendarIds"
                            SelectedCalendarIdsChanged="ids => { _selectedCalendarIds = ids; }"
                            EventId="@(_isEditingEvent ? (Guid?)_eventModel.Id : null)"
                            CalendarApi="CalendarApi" />
                        @if (_selectedCalendarIds.Count == 0)
                        {
                            <div class="text-danger mt-1" style="font-size: 0.82rem;">Please select at least one calendar.</div>
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Event Title</label>
                        <input type="text" class="form-input" @bind="_eventModel.Title" placeholder="e.g. Doctor Appointment" />
                    </div>
                    <div class="pill-toggle-row mb-3">
                        <span class="pill-toggle-label" id="allDayLabel">All Day Event</span>
                        <button type="button"
                                class="@($"pill-toggle {(_eventModel.IsAllDay ? "pill-toggle--on" : "pill-toggle--off")}")"
                                data-testid="all-day-toggle"
                                aria-labelledby="allDayLabel"
                                aria-pressed="@_eventModel.IsAllDay.ToString().ToLowerInvariant()"
                                @onclick="() => _eventModel.IsAllDay = !_eventModel.IsAllDay">
                            @(_eventModel.IsAllDay ? "On" : "Off")
                        </button>
                    </div>
                    <div class="grid-2 mb-3">
                        <div>
                            <label class="form-label">Start Date</label>
                            <input type="date" class="form-input" @bind="_startDate" />
                        </div>
                        <div>
                            <label class="form-label">End Date</label>
                            <input type="date" class="form-input" @bind="_endDate" />
                        </div>
                    </div>
                    @if (!_eventModel.IsAllDay)
                    {
                        <div class="grid-2 mb-3">
                            <div data-testid="start-time-picker">
                                <label class="form-label">Start Time</label>
                                <TimePicker Value="_startTime" ValueChanged="v => _startTime = v" AriaLabel="Start time" />
                            </div>
                            <div data-testid="end-time-picker">
                                <label class="form-label">End Time</label>
                                <TimePicker Value="_endTime" ValueChanged="v => _endTime = v" AriaLabel="End time" />
                            </div>
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Location (Optional)</label>
                        <input type="text" class="form-input" @bind="_eventModel.Location" placeholder="e.g. 123 Main St" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description (Optional)</label>
                        <textarea class="form-input" rows="3" @bind="_eventModel.Description"
                                  placeholder="Notes, details…"></textarea>
                    </div>
                    @if (!string.IsNullOrEmpty(_modalError))
                    {
                        <div class="alert alert-danger">@_modalError</div>
                    }
                </div>
                <div class="modal-footer flex justify-between">
                    <div>
                        @if (_isEditingEvent)
                        {
                            <button type="button" class="btn btn-danger" @onclick="DeleteEvent">Delete</button>
                        }
                    </div>
                    <div>
                        <button type="button" class="btn btn-secondary" @onclick="Close">Cancel</button>
                        <button type="button" class="btn btn-primary" @onclick="SaveEvent" disabled="@_isSaving">
                            @if (_isSaving)
                            {
                                <span class="spinner spinner-sm" role="status" aria-hidden="true"></span>
                                <span class="sr-only">Saving...</span>
                            }
                            else
                            {
                                <span>Save</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public IReadOnlyList<CalendarSummaryViewModel> Calendars { get; set; } = Array.Empty<CalendarSummaryViewModel>();
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnDeleted { get; set; }

    // Pills in the event modal should only expose calendars that represent a real family
    // member — the shared calendar and any hidden calendars are not selectable here.
    // Shared calendar membership is implicit (multi-member events route there automatically)
    // and hidden calendars are intentionally excluded from the kiosk display, so selecting
    // them would be misleading.
    private IReadOnlyList<CalendarSummaryViewModel> SelectableCalendars =>
        Calendars.Where(c => !c.IsShared && c.IsVisible).ToList();

    private bool _showEventModal;
    private bool _isEditingEvent;
    private EventFormModel _eventModel = new();
    private HashSet<Guid> _selectedCalendarIds = new();
    private string? _modalError;
    private bool _isSaving;

    private DateTime _startDate
    {
        get => _eventModel.Start.LocalDateTime.Date;
        set
        {
            var time = _eventModel.Start.LocalDateTime.TimeOfDay;
            var dt = value.Date + time;
            _eventModel.Start = new DateTimeOffset(dt, TimeZoneInfo.Local.GetUtcOffset(dt));
            SyncEndDateIfNeeded();
        }
    }

    private DateTime _endDate
    {
        // For all-day events, End is stored as the exclusive next-day boundary
        // (matching Google's contract). Display the inclusive last day so the
        // user sees the date they picked. AddTicks(-1).Date also handles legacy
        // rows where End may have been stored as the inclusive end-of-day tick.
        get => _eventModel.IsAllDay
            ? _eventModel.End.LocalDateTime.AddTicks(-1).Date
            : _eventModel.End.LocalDateTime.Date;
        set
        {
            var time = _eventModel.End.LocalDateTime.TimeOfDay;
            var dt = _eventModel.IsAllDay
                ? value.Date.AddDays(1)
                : value.Date + time;
            _eventModel.End = new DateTimeOffset(dt, TimeZoneInfo.Local.GetUtcOffset(dt));
        }
    }

    private TimeOnly _startTime
    {
        get => TimeOnly.FromTimeSpan(_eventModel.Start.LocalDateTime.TimeOfDay);
        set
        {
            // Shift end by the same delta so the user-visible duration is preserved
            // when only the start time is moved. Editing the end time independently
            // (see _endTime) does not touch the start.
            var oldStart = _eventModel.Start;
            var newStartLocal = oldStart.LocalDateTime.Date + value.ToTimeSpan();
            var newStart = new DateTimeOffset(newStartLocal, TimeZoneInfo.Local.GetUtcOffset(newStartLocal));
            var delta = newStart - oldStart;
            _eventModel.Start = newStart;
            _eventModel.End = _eventModel.End + delta;
        }
    }

    private TimeOnly _endTime
    {
        get => TimeOnly.FromTimeSpan(_eventModel.End.LocalDateTime.TimeOfDay);
        set
        {
            var dt = _eventModel.End.LocalDateTime.Date + value.ToTimeSpan();
            _eventModel.End = new DateTimeOffset(dt, TimeZoneInfo.Local.GetUtcOffset(dt));
        }
    }

    private IEnumerable<Guid> DetectMemberIdsInDescription(string? description)
    {
        if (string.IsNullOrWhiteSpace(description))
            return Array.Empty<Guid>();

        // Match whole-word, case-insensitive. Unknown names are skipped.
        // Only selectable calendars (non-shared, non-hidden) are candidates — mentioning the
        // shared calendar name in the description should not tag the event with the shared
        // calendar as a member, since shared is the routing target, not a member.
        var matched = new List<Guid>();
        foreach (var cal in SelectableCalendars)
        {
            if (Regex.IsMatch(description, $@"\b{Regex.Escape(cal.DisplayName)}\b", RegexOptions.IgnoreCase))
                matched.Add(cal.Id);
        }
        return matched;
    }

    private void SyncEndDateIfNeeded()
    {
        if (_eventModel.End < _eventModel.Start)
        {
            var duration = TimeSpan.FromHours(1);
            _eventModel.End = _eventModel.Start + duration;
        }
    }

    public void OpenForCreate(DateTime date, Guid? calendarId = null)
    {
        _isEditingEvent = false;
        var start = date.Hour == 0 && date.Minute == 0 ? date.AddHours(9) : date;
        var end = start.AddHours(1);
        _eventModel = new EventFormModel
        {
            Title = "",
            Start = new DateTimeOffset(start, TimeZoneInfo.Local.GetUtcOffset(start)),
            End = new DateTimeOffset(end, TimeZoneInfo.Local.GetUtcOffset(end)),
            IsAllDay = false
        };
        var targetCalendarId = calendarId ?? Calendars.FirstOrDefault()?.Id ?? Guid.Empty;
        _selectedCalendarIds = targetCalendarId != Guid.Empty ? [targetCalendarId] : [];
        _modalError = null;
        _showEventModal = true;
        StateHasChanged();
    }

    public void OpenForEdit(CalendarEventViewModel evt)
    {
        _isEditingEvent = true;
        _eventModel = new EventFormModel
        {
            Id = evt.Id,
            Title = evt.Title,
            Start = evt.Start,
            End = evt.End,
            IsAllDay = evt.IsAllDay,
            Location = evt.Location,
            Description = evt.Description,
            AllCalendars = evt.AllCalendars.ToList()
        };
        _selectedCalendarIds = evt.AllCalendars.Select(c => c.Id).ToHashSet();
        _modalError = null;
        _showEventModal = true;
        StateHasChanged();
    }

    private void Close()
    {
        _showEventModal = false;
        _eventModel = new();
        _modalError = null;
    }

    private async Task SaveEvent()
    {
        _modalError = null;

        if (string.IsNullOrWhiteSpace(_eventModel.Title))
        {
            _modalError = "Title is required.";
            return;
        }

        // Merge pill selection with any member names detected in the description.
        // The description is the source of truth for extra members — pills are additive.
        // Unknown names in the description are ignored.
        var effectiveMemberIds = new HashSet<Guid>(_selectedCalendarIds);
        foreach (var id in DetectMemberIdsInDescription(_eventModel.Description))
        {
            effectiveMemberIds.Add(id);
        }

        if (effectiveMemberIds.Count == 0)
        {
            _modalError = "Please select at least one calendar.";
            return;
        }
        if (_eventModel.End < _eventModel.Start)
        {
            _modalError = "End time must be after start time.";
            return;
        }

        _isSaving = true;
        try
        {
            if (_isEditingEvent)
            {
                var updateReq = new UpdateEventRequest(
                    _eventModel.Title,
                    _eventModel.Start,
                    _eventModel.End,
                    _eventModel.IsAllDay,
                    _eventModel.Location,
                    _eventModel.Description);
                await CalendarApi.UpdateEventAsync(_eventModel.Id, updateReq);
            }
            else
            {
                var createReq = new CreateEventRequest(
                    effectiveMemberIds.ToList(),
                    _eventModel.Title,
                    _eventModel.Start,
                    _eventModel.End,
                    _eventModel.IsAllDay,
                    _eventModel.Location,
                    _eventModel.Description);
                await CalendarApi.CreateEventAsync(createReq);
            }
            Close();
            await OnSaved.InvokeAsync();
        }
        catch (Exception ex)
        {
            _modalError = "An error occurred while saving.";
            Console.WriteLine(ex.ToString());
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteEvent()
    {
        if (_eventModel.Id == Guid.Empty) return;
        _isSaving = true;
        try
        {
            await CalendarApi.DeleteEventAsync(_eventModel.Id);
            Close();
            await OnDeleted.InvokeAsync();
        }
        catch (Exception ex)
        {
            _modalError = "An error occurred while deleting.";
            Console.WriteLine(ex.ToString());
        }
        finally
        {
            _isSaving = false;
        }
    }

    private class EventFormModel
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = "";
        public DateTimeOffset Start { get; set; }
        public DateTimeOffset End { get; set; }
        public bool IsAllDay { get; set; }
        public string? Location { get; set; }
        public string? Description { get; set; }
        public List<CalendarSummaryViewModel> AllCalendars { get; set; } = new();
    }
}
