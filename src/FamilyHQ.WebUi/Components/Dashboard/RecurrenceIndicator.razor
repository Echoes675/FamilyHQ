@* FHQ-18.10: presentational repeat glyph rendered on recurring event tiles across the
   Day / Month / Agenda views. Inline SVG uses currentColor so it inherits the tile's
   theme text colour, and carries no animation (Pi 3B+ rule). The parent decides whether
   to render this (gated on IsRecurring). *@
<svg class="event-tile__recur-icon" data-testid="recurrence-indicator"
     xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
     role="img" aria-label="Repeats">
    <title>Repeats</title>
    <polyline points="23 4 23 10 17 10"></polyline>
    <polyline points="1 20 1 14 7 14"></polyline>
    <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
</svg>
