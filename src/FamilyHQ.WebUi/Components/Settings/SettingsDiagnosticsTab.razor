@namespace FamilyHQ.WebUi.Components.Settings
@using FamilyHQ.Core.DTOs
@using FamilyHQ.WebUi.Components.Diagnostics
@using FamilyHQ.WebUi.Services
@using Microsoft.Extensions.Logging
@inject IDiagnosticsApiService DiagnosticsApi
@inject ICalendarApiService CalendarApi
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inject TimeProvider TimeProvider
@inject ILogger<SettingsDiagnosticsTab> Logger

<div class="settings-section-content">
    <div class="diagnostics-header">
        <h2 class="settings-section__title">Diagnostics</h2>
        <button type="button"
                class="btn btn-primary diagnostics-sync-all-btn"
                data-testid="diagnostics-sync-all-btn"
                @onclick="SyncAllAsync"
                disabled="@(_isSyncing || _isLoading)">
            @if (_isSyncing)
            {
                <span class="spinner spinner-sm" role="status" aria-hidden="true"></span>
                <span>Syncing…</span>
            }
            else
            {
                <span>Sync All</span>
            }
        </button>
        <button type="button"
                class="btn btn-secondary diagnostics-refresh-btn"
                data-testid="diagnostics-refresh-btn"
                @onclick="RefreshAsync"
                disabled="@(_isLoading || _isSyncing)">
            @if (_isLoading)
            {
                <span class="spinner spinner-sm" role="status" aria-hidden="true"></span>
                <span>Refreshing…</span>
            }
            else
            {
                <span>Refresh</span>
            }
        </button>
    </div>

    @if (!string.IsNullOrEmpty(_syncMessage))
    {
        <p class="alert alert-success" data-testid="diagnostics-sync-message">@_syncMessage</p>
    }
    @if (!string.IsNullOrEmpty(_syncError))
    {
        <p class="alert alert-error" data-testid="diagnostics-sync-error">@_syncError</p>
    }

    @if (_loadFailed)
    {
        <div class="alert alert-warning" data-testid="diagnostics-load-error">
            Unable to load diagnostics. Please try again.
        </div>
    }

    <section class="diagnostics-section" aria-labelledby="diagnostics-connection-heading">
        <h2 id="diagnostics-connection-heading" data-testid="diagnostics-connection-heading" class="diagnostics-section__title">Connection status</h2>

        @if (_connectionStatus is null && !_loadFailed)
        {
            <p class="diagnostics-empty" data-testid="diagnostics-connection-loading">Loading connection status…</p>
        }
        else if (_connectionStatus is not null)
        {
            <div class="diagnostics-connection">
                <div class="diagnostics-connection__summary">
                    <span class="@DiagnosticsView.StatusBadgeCssClass(_connectionStatus)"
                          data-testid="diagnostics-status-badge">
                        @DiagnosticsView.StatusBadgeLabel(_connectionStatus)
                    </span>

                    @if (DiagnosticsView.IsNeedsReauth(_connectionStatus))
                    {
                        <div class="diagnostics-connection__detail">
                            @if (!string.IsNullOrWhiteSpace(_connectionStatus.LastError))
                            {
                                <p class="diagnostics-connection__error" data-testid="diagnostics-last-error">
                                    @_connectionStatus.LastError
                                </p>
                            }
                            @if (_connectionStatus.Since.HasValue)
                            {
                                <p class="diagnostics-connection__since" data-testid="diagnostics-since">
                                    Since <time title="@DiagnosticsView.FormatAbsolute(_connectionStatus.Since.Value)">
                                        @DiagnosticsView.FormatRelative(_connectionStatus.Since.Value, _now)
                                    </time>
                                </p>
                            }
                        </div>
                    }
                </div>

                @if (DiagnosticsView.IsNeedsReauth(_connectionStatus))
                {
                    <button type="button"
                            class="btn btn-primary diagnostics-reconnect-btn"
                            data-testid="diagnostics-reconnect-btn"
                            @onclick="ReconnectToGoogle">
                        Reconnect to Google
                    </button>
                }
            </div>

            @if (_connectionStatus.Calendars.Count > 0)
            {
                <table class="diagnostics-table" data-testid="diagnostics-calendars-table">
                    <thead>
                        <tr>
                            <th scope="col">Calendar</th>
                            <th scope="col">Last synced</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cal in _connectionStatus.Calendars)
                        {
                            <tr>
                                <td>@cal.DisplayName</td>
                                <td>
                                    @if (cal.LastSyncedAt.HasValue)
                                    {
                                        <time title="@DiagnosticsView.FormatAbsolute(cal.LastSyncedAt.Value)">
                                            @DiagnosticsView.FormatRelative(cal.LastSyncedAt.Value, _now)
                                        </time>
                                    }
                                    else
                                    {
                                        <span class="diagnostics-muted">Never</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }
    </section>

    <section class="diagnostics-section" aria-labelledby="diagnostics-failures-heading">
        <h2 id="diagnostics-failures-heading" class="diagnostics-section__title">Recent sync failures</h2>
        <p class="diagnostics-section__caption">Individual events that could not be saved.</p>

        @if (DiagnosticsView.ShouldShowEmptyState(_failures))
        {
            <p class="diagnostics-empty" data-testid="diagnostics-failures-empty">
                No failures recorded — sync is healthy.
            </p>
        }
        else
        {
            <table class="diagnostics-table" data-testid="diagnostics-failures-table">
                <thead>
                    <tr>
                        <th scope="col">When</th>
                        <th scope="col">Calendar</th>
                        <th scope="col">Event</th>
                        <th scope="col">Failure reason</th>
                        <th scope="col">Exception</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var failure in _failures!)
                    {
                        <tr>
                            <td>
                                <time title="@DiagnosticsView.FormatAbsolute(failure.FailedAt)">
                                    @DiagnosticsView.FormatRelative(failure.FailedAt, _now)
                                </time>
                            </td>
                            <td>@ResolveCalendarName(failure.CalendarInfoId)</td>
                            <td>@(string.IsNullOrWhiteSpace(failure.EventTitle) ? failure.GoogleEventId : failure.EventTitle)</td>
                            <td>@failure.FailureReason</td>
                            <td><code>@failure.ExceptionType</code></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <section class="diagnostics-section" aria-labelledby="diagnostics-runs-heading">
        <h2 id="diagnostics-runs-heading" class="diagnostics-section__title">Recent failed sync runs</h2>
        <p class="diagnostics-section__caption">Whole sync attempts that gave up after retries. These re-run automatically on the next change — no action needed.</p>

        @if (_failedRuns is null || _failedRuns.Count == 0)
        {
            <p class="diagnostics-empty" data-testid="diagnostics-runs-empty">
                No failed sync runs — automatic sync is healthy.
            </p>
        }
        else
        {
            <table class="diagnostics-table" data-testid="diagnostics-runs-table">
                <thead>
                    <tr>
                        <th scope="col">When</th>
                        <th scope="col">Calendar</th>
                        <th scope="col">Source</th>
                        <th scope="col">Attempts</th>
                        <th scope="col">Last error</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var run in _failedRuns)
                    {
                        <tr>
                            <td><time title="@DiagnosticsView.FormatAbsolute(run.LastAttemptAt)">@DiagnosticsView.FormatRelative(run.LastAttemptAt, _now)</time></td>
                            <td>@(run.CalendarInfoId is null ? "All calendars" : ResolveCalendarName(run.CalendarInfoId))</td>
                            <td>@run.Source</td>
                            <td>@run.AttemptCount</td>
                            <td>@run.LastError</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
</div>

@code {
    private ConnectionStatusWithCalendarsDto? _connectionStatus;
    private IReadOnlyList<SyncFailureDto>? _failures;
    private IReadOnlyList<FailedSyncRunDto>? _failedRuns;
    private bool _isLoading;
    private bool _isSyncing;
    private string? _syncMessage;
    private string? _syncError;
    private bool _connectionStatusFailed;
    private bool _failuresFailed;
    private bool _failedRunsFailed;
    private DateTimeOffset _now;

    private bool _loadFailed => _connectionStatusFailed || _failuresFailed || _failedRunsFailed;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task RefreshAsync() => await LoadAsync();

    private async Task SyncAllAsync()
    {
        _isSyncing = true;
        _syncMessage = null;
        _syncError = null;
        StateHasChanged();
        try
        {
            await CalendarApi.TriggerSyncAsync();
            await LoadAsync();
            _syncMessage = "Sync completed.";
        }
        catch (Exception ex)
        {
            // TriggerSyncAsync surfaces 409 (re-auth) / 502 as a failed status code; the
            // connection-status section above shows the re-auth detail, so a concise message suffices.
            Logger.LogWarning(ex, "Manual Sync All from diagnostics tab failed");
            _syncError = "Sync failed. Please try again.";
        }
        finally
        {
            _isSyncing = false;
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _connectionStatusFailed = false;
        _failuresFailed = false;
        _failedRunsFailed = false;
        _now = TimeProvider.GetUtcNow();
        StateHasChanged();

        var statusTask = DiagnosticsApi.GetConnectionStatusAsync();
        var failuresTask = DiagnosticsApi.GetSyncFailuresAsync();
        var failedRunsTask = DiagnosticsApi.GetFailedSyncRunsAsync();
        await Task.WhenAll(statusTask, failuresTask, failedRunsTask);

        var statusResult = await statusTask;
        var failuresResult = await failuresTask;
        var failedRunsResult = await failedRunsTask;

        _connectionStatus = statusResult.Data;
        _connectionStatusFailed = !statusResult.Loaded;
        _failures = failuresResult.Data;
        _failuresFailed = !failuresResult.Loaded;
        _failedRuns = failedRunsResult.Data;
        _failedRunsFailed = !failedRunsResult.Loaded;
        _isLoading = false;
        StateHasChanged();
    }

    private string ResolveCalendarName(Guid? calendarInfoId)
    {
        if (calendarInfoId is null) return "(deleted calendar)";
        if (_connectionStatus is null) return calendarInfoId.Value.ToString();
        var match = _connectionStatus.Calendars.FirstOrDefault(c => c.CalendarId == calendarInfoId.Value);
        return match?.DisplayName ?? calendarInfoId.Value.ToString();
    }

    private void ReconnectToGoogle()
    {
        var backendUrl = Configuration["BackendUrl"]
            ?? throw new InvalidOperationException("BackendUrl is not configured.");
        Navigation.NavigateTo($"{backendUrl}/api/auth/login", forceLoad: true);
    }
}
