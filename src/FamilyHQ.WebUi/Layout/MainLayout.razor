@inherits LayoutComponentBase
@using FamilyHQ.WebUi.Services
@inject IThemeService ThemeService
@inject IDisplaySettingService DisplaySettingService
@inject IWeatherUiService WeatherUiService

<div class="page">
    <ErrorBoundary @ref="_errorBoundary">
        <ChildContent>
            @Body
        </ChildContent>
        <ErrorContent>
            <div class="error-boundary-container">
                <div class="glass-surface error-boundary-card">
                    <h2>Something went wrong</h2>
                    <p>An unexpected error occurred. Please try again.</p>
                    <button class="btn btn-primary" @onclick="Recover">Reload</button>
                </div>
            </div>
        </ErrorContent>
    </ErrorBoundary>
</div>

@code {
    private ErrorBoundary? _errorBoundary;

    protected override async Task OnInitializedAsync()
    {
        await ThemeService.InitialiseAsync();
        await DisplaySettingService.InitialiseAsync();
        await WeatherUiService.InitialiseAsync();
    }

    private void Recover()
    {
        _errorBoundary?.Recover();
    }
}
