@inherits LayoutComponentBase
@using FamilyHQ.WebUi.Services
@inject IThemeService ThemeService

<div class="page">
    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await ThemeService.InitialiseAsync();
    }
}
