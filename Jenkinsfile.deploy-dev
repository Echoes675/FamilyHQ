pipeline {
    agent any

    options {
        disableConcurrentBuilds()
    }

    tools {
        dotnetsdk '.Net_10.0_SDK'
    }

    parameters {
        string(name: 'BRANCH', defaultValue: '', description: 'Branch name to deploy (e.g. dev, feature/my-feature). Leave empty to use current branch.')
    }

    environment {
        REGISTRY = 'registry.alphaepsilon.co.uk'
        REGISTRY_URL = "https://${REGISTRY}"
        DEPLOY_HOST = 'jenkins_docker@192.168.86.23'
        DEPLOY_PATH = '/Docker/deployed_apps/dev/familyhq'
        APP_BASE_URL = 'http://192.168.86.23:8200'
        DB_NAME = 'FamilyHQ-Dev'
        SIMULATOR_DB_NAME = 'FamilyHQ-Simulator-Dev'
    }

    stages {
        stage('Resolve Image') {
            steps {
                echo '======= Resolve Image ======='
                script {
                    def branch = params.BRANCH?.trim() ?: env.BRANCH_NAME ?: 'dev'
                    def branchSanitized = branch.replaceAll('[^a-zA-Z0-9_.-]', '-').toLowerCase()
                    echo "Resolving latest image for branch: ${branch} (sanitized: ${branchSanitized})"

                    def tagsJson = ''
                    withCredentials([usernameColonPassword(credentialsId: 'alphaepsilon-docker-registry', variable: 'REGISTRY_CREDS')]) {
                        tagsJson = sh(
                            script: "curl -sk -u \$REGISTRY_CREDS ${REGISTRY_URL}/v2/familyhq-webapi/tags/list",
                            returnStdout: true
                        ).trim()
                    }

                    def tags = readJSON(text: tagsJson).tags ?: []
                    def branchTags = []
                    for (t in tags) {
                        if (t.startsWith("${branchSanitized}-")) {
                            branchTags.add(t)
                        }
                    }
                    branchTags.sort()

                    if (branchTags.isEmpty()) {
                        error "No images found for branch '${branch}' (prefix: ${branchSanitized}-)"
                    }

                    env.RESOLVED_IMAGE_TAG = branchTags.last()
                    echo "Resolved image tag: ${env.RESOLVED_IMAGE_TAG}"
                }
            }
        }

        stage('Prepare') {
            steps {
                echo '======= Prepare ======='
                checkout scm

                withCredentials([
                    file(credentialsId: 'familyhq-dev-env', variable: 'ENV_FILE'),
                    file(credentialsId: 'familyhq-dev-dp-cert', variable: 'DP_CERT')
                ]) {
                    sshagent(credentials: ['jenkins_docker_dev']) {
                        sh """
                            ssh -o StrictHostKeyChecking=no ${DEPLOY_HOST} 'mkdir -p ${DEPLOY_PATH}'
                            scp docker-compose.yml docker-compose.dev.yml ${DEPLOY_HOST}:${DEPLOY_PATH}/
                            scp \$ENV_FILE ${DEPLOY_HOST}:${DEPLOY_PATH}/.env
                            scp \$DP_CERT ${DEPLOY_HOST}:${DEPLOY_PATH}/dataprotection.pfx
                            ssh -o StrictHostKeyChecking=no ${DEPLOY_HOST} 'chmod 640 ${DEPLOY_PATH}/.env && chmod 640 ${DEPLOY_PATH}/dataprotection.pfx'
                        """
                    }
                }
            }
        }

        stage('Drop DBs') {
            steps {
                echo '======= Drop DBs ======='
                sshagent(credentials: ['jenkins_docker_dev']) {
                    sh """
                        ssh -o StrictHostKeyChecking=no ${DEPLOY_HOST} '
                            cd ${DEPLOY_PATH} &&
                            docker compose -f docker-compose.yml -f docker-compose.dev.yml down --remove-orphans || true

                            docker exec postgres-db-1 psql -U devdbuser -c "SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname = '"'"'${DB_NAME}'"'"' AND pid <> pg_backend_pid();"
                            docker exec postgres-db-1 psql -U devdbuser -c "DROP DATABASE IF EXISTS \\"${DB_NAME}\\";"
                            docker exec postgres-db-1 psql -U devdbuser -c "CREATE DATABASE \\"${DB_NAME}\\";"
                            docker exec postgres-db-1 psql -U devdbuser -c "SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname = '"'"'${SIMULATOR_DB_NAME}'"'"' AND pid <> pg_backend_pid();"
                            docker exec postgres-db-1 psql -U devdbuser -c "DROP DATABASE IF EXISTS \\"${SIMULATOR_DB_NAME}\\";"
                            docker exec postgres-db-1 psql -U devdbuser -c "CREATE DATABASE \\"${SIMULATOR_DB_NAME}\\";"
                        '
                    """
                }
            }
        }

        stage('Deploy') {
            steps {
                echo '======= Deploy ======='
                sshagent(credentials: ['jenkins_docker_dev']) {
                    sh """
                        ssh -o StrictHostKeyChecking=no ${DEPLOY_HOST} '
                            cd ${DEPLOY_PATH} &&
                            export IMAGE_TAG=${env.RESOLVED_IMAGE_TAG} &&
                            docker compose -f docker-compose.yml -f docker-compose.dev.yml pull &&
                            docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --remove-orphans
                        '
                    """
                }
            }
        }

        stage('Wait for Services') {
            steps {
                echo '======= Wait for Services ======='
                script {
                    def endpoints = [
                        [name: 'WebUI',     url: "${APP_BASE_URL}/health"],
                        [name: 'WebAPI',    url: "${APP_BASE_URL}/api/health"],
                        [name: 'Simulator', url: "${APP_BASE_URL}/simulator/health"]
                    ]

                    def branches = [:]
                    for (ep in endpoints) {
                        def name = ep.name
                        def url = ep.url
                        branches[name] = {
                            def maxRetries = 18
                            for (int i = 0; i < maxRetries; i++) {
                                def status = sh(
                                    script: "curl -s -o /dev/null -w '%{http_code}' ${url} || echo '000'",
                                    returnStdout: true
                                ).trim()

                                if (status == '200') {
                                    echo "${name} ready (HTTP ${status})"
                                    return
                                }
                                echo "${name} not ready... attempt ${i + 1}/${maxRetries} (HTTP ${status})"
                                sleep(time: 10, unit: 'SECONDS')
                            }
                            error "${name} not ready after 3 minutes"
                        }
                    }
                    parallel branches
                }
            }
        }

        stage('E2E Tests') {
            steps {
                echo '======= E2E Tests ======='
                withEnv(['DOTNET_SYSTEM_GLOBALIZATION_INVARIANT=true']) {
                    sh 'dotnet build tests-e2e/FamilyHQ.E2E.Features/FamilyHQ.E2E.Features.csproj -c Release'
                    sh 'pwsh tests-e2e/FamilyHQ.E2E.Features/bin/Release/net10.0/playwright.ps1 install chromium --with-deps'
                    sh """
                        TestConfiguration__BaseUrl=${APP_BASE_URL} \
                        TestConfiguration__ApiBaseUrl=${APP_BASE_URL} \
                        TestConfiguration__SimulatorApiUrl=${APP_BASE_URL}/simulator \
                        TestConfiguration__Headless=true \
                        dotnet test tests-e2e/FamilyHQ.E2E.Features/FamilyHQ.E2E.Features.csproj \
                            -c Release --no-build \
                            --logger "trx;LogFileName=e2e-results.trx"
                    """
                }
            }
            post {
                always {
                    mstest testResultsFile: '**/e2e-results.trx', failOnError: false
                }
            }
        }
    }

    post {
        success {
            echo "Dev deployment successful: ${env.RESOLVED_IMAGE_TAG}"
        }
        failure {
            echo "Dev deployment failed: ${env.RESOLVED_IMAGE_TAG}"
        }
    }
}
